# VITE_* variables are inlined at build time by Vite.
# Changing these on Vercel requires a new deployment, not just a restart.

# Railway API URL (no trailing slash)
VITE_API_URL=https://your-app.up.railway.app

# Shared secret sent with every AI request (must match APP_SECRET_KEY on Railway)
VITE_APP_KEY=

# Sentry DSN for frontend error tracking (leave empty to disable)
VITE_SENTRY_DSN=
